        },
        {
          "name": "Brand Color 10",
          "slug": "brand-10",
          "color": "#d9edff"
        }
      ]
    },
    "custom": {
      "layout": {
        "contentSize": "1440px"
      },
      "spacing": {
        "20": "0.25rem",
        "30": "0.5rem",
        "40": "1rem",
        "50": "1.5rem",
        "60": "2rem",
        "70": "3rem",
        "80": "4rem"
      },
      "font-size": {
        "mobile": {
          "heading1": "40px",
          "heading2": "34px",
          "heading3": "26px",
          "heading4": "22px",
          "heading5": "24px",
          "heading6": "16px",
          "bodySmall": "12px",
          "bodyMedium": "14px",
          "bodyLarge": "16px"
        },
        "desktop": {
          "heading1": "64px",
          "heading2": "40px",
          "heading3": "30px",
          "heading4": "24px",
          "heading5": "20px",
          "heading6": "24px",
          "bodySmall": "16px",
          "bodyMedium": "18px",
          "bodyLarge": "20px"
        }
      }
    },
    "layout": {
      "contentSize": "var(--wp--custom--layout--content-size)"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": [
        "rem",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
          "size": "var(--wp--custom--spacing--20)",
          "slug": "20",
          "name": "XS"
        },
        {
          "size": "var(--wp--custom--spacing--30)",
          "slug": "30",
          "name": "SM"
        },
        {
          "size": "var(--wp--custom--spacing--40)",
          "slug": "40",
          "name": "MD"
        },
        {
          "size": "var(--wp--custom--spacing--50)",
          "slug": "50",
          "name": "LG"
        },
        {
          "size": "var(--wp--custom--spacing--60)",
          "slug": "60",
          "name": "XL"
        },
        {
          "size": "var(--wp--custom--spacing--70)",
          "slug": "70",
          "name": "2XL"
        },
        {
          "size": "var(--wp--custom--spacing--80)",
          "slug": "80",
          "name": "3XL"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "lineHeight": false,
      "dropCap": false,
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "var(--wp--custom--font-size--desktop--body-small)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "var(--wp--custom--font-size--desktop--body-medium)"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "var(--wp--custom--font-size--desktop--body-large)"
        }
      ],
      "fontFamilies": [
        {
          "name": "Montserrat",
          "slug": "geist-mono",
          "fontFamily": "Montserrat, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Montserrat",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/montserrat/Montserrat-Regular.woff2"
              ]
            },
            {
              "fontFamily": "Montserrat",
              "fontWeight": "500",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/montserrat/Montserrat-Medium.woff2"
              ]
            }
          ]
        },
        {
          "name": "Instrument Sans",
          "slug": "urbanist",
          "fontFamily": "Instrument Sans, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Instrument Sans",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/instrument-sans/InstrumentSans-Regular.woff2"
              ]
            },
            {
              "fontFamily": "Instrument Sans",
              "fontWeight": "600",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/instrument-sans/InstrumentSans-SemiBold.woff2"
              ]
            }
          ]
        }
      ]
    },
    "blocks": {
      "core/columns": {
        "spacing": {
          "blockGap": true
        }
      },
      "core/button": {
        "color": {
          "palette": []
        }
      }
    }
